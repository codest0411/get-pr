{
  "manifest_version": 3,
  "name": "get-PR — AI PR Descriptions",
  "description": "Auto-generate GitHub PR titles, summaries, breaking changes and reviewer suggestions using free Claude AI",
  "version": "1.0.0",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://github.com/*",
    "https://api.puter.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*/pull/*",
        "https://github.com/*/pulls/*",
        "https://github.com/*/compare/*"
      ],
      "js": [
        "puter.js",
        "prompt.js",
        "extractor.js",
        "ui/button.js",
        "ui/panel.js",
        "content.js"
      ],
      "css": ["ui/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "get-PR",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
